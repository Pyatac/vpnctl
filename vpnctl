#!/bin/bash
set -e

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

SCRIPT_DIR="$(cd -- "$(dirname -- "$(readlink -f "$0")")" && pwd)"
DATA_DIR="${VPNCTL_DATA_DIR:-$HOME/.config/vpnctl}"

CONFIG_FILE="$DATA_DIR/config.cfg"
CLIENTS_DIR="$DATA_DIR/clients"
CLIENTS_TXT="$DATA_DIR/clients.txt"
BUILDS_DIR="$DATA_DIR/builds"
BACKUP_DIR="$DATA_DIR/backups"
TEMPLATE="$DATA_DIR/template.json"
BUILD="$BUILDS_DIR/config.json"

REAL_CONFIG="/etc/sing-box/config.json"
SERVICE_NAME="sing-box"

mkdir -p "$CLIENTS_DIR" "$BUILDS_DIR" "$BACKUP_DIR"

load_config() {
  if [ ! -f "$CONFIG_FILE" ]; then
    echo "Config not found: $CONFIG_FILE"
    echo "Run: vpnctl setup"
    exit 1
  fi

  source "$CONFIG_FILE"
}

make_link() {
  local uuid="$1"
  local name="$2"

  echo "vless://${uuid}@${SERVER}:${PORT}?type=tcp&security=reality&sni=${SNI}&fp=chrome&pbk=${PUBLIC_KEY}&sid=${SHORT_ID}&flow=${FLOW}#${name}"
}

write_clients_txt() {
  load_config

  : > "$CLIENTS_TXT"

  local n=1
  local file name uuid

  for file in "$CLIENTS_DIR"/*.json; do
    [ -e "$file" ] || continue

    name="$(jq -r '.name' "$file")"
    uuid="$(jq -r '.uuid' "$file")"

    echo "$n - $name - $(make_link "$uuid" "$name")" >> "$CLIENTS_TXT"
    n=$((n + 1))
  done
}

validate_name() {
  echo "$1" | grep -Eq '^[A-Za-z0-9_-]+$' || {
    echo "Invalid name. Use only: A-Z a-z 0-9 _ -"
    exit 1
  }
}

add_client() {
  load_config

  local name="$1"
  [ -z "$name" ] && echo "Client name required" && exit 1
  validate_name "$name"

  local file="$CLIENTS_DIR/${name}.json"

  [ -f "$file" ] && echo "Client already exists: $name" && exit 1
  [ -f "$file.disabled" ] && echo "Client already exists but disabled: $name" && exit 1

  local uuid
  uuid="$(sing-box generate uuid)"

  cat > "$file" <<EOF_CLIENT
{
  "name": "$name",
  "uuid": "$uuid",
  "flow": "$FLOW",
  "created": "$(date +%Y-%m-%d)"
}
EOF_CLIENT

  echo "Client created: $name"
  echo
  make_link "$uuid" "$name"
  echo

  write_clients_txt
  build_config
}

list_clients() {
  printf "%-24s %-12s %-36s\n" "NAME" "CREATED" "UUID"
  printf "%-24s %-12s %-36s\n" "----" "-------" "----"

  local file

  for file in "$CLIENTS_DIR"/*.json; do
    [ -e "$file" ] || return 0
    jq -r '[.name, .created, .uuid] | @tsv' "$file" |
      awk -F '\t' '{printf "%-24s %-12s %-36s\n", $1, $2, $3}'
  done
}

show_client() {
  load_config

  local name="$1"
  [ -z "$name" ] && echo "Client name required" && exit 1
  validate_name "$name"

  local file="$CLIENTS_DIR/${name}.json"
  [ ! -f "$file" ] && echo "Client not found: $name" && exit 1

  local uuid
  uuid="$(jq -r '.uuid' "$file")"

  make_link "$uuid" "$name"
}

remove_client() {
  load_config

  local name="$1"
  [ -z "$name" ] && echo "Client name required" && exit 1
  validate_name "$name"

  local file="$CLIENTS_DIR/${name}.json"
  local disabled_file="$CLIENTS_DIR/${name}.json.disabled"

  if [ ! -f "$file" ] && [ ! -f "$disabled_file" ]; then
    echo "Client not found: $name"
    exit 1
  fi

  rm -f "$file" "$disabled_file"

  echo "Client removed: $name"

  write_clients_txt
  build_config
}

disable_client() {
  load_config

  local name="$1"
  [ -z "$name" ] && echo "Client name required" && exit 1
  validate_name "$name"

  local file="$CLIENTS_DIR/${name}.json"
  local disabled_file="$CLIENTS_DIR/${name}.json.disabled"

  [ -f "$disabled_file" ] && echo "Client already disabled: $name" && exit 1
  [ ! -f "$file" ] && echo "Client not found: $name" && exit 1

  mv "$file" "$disabled_file"

  echo "Client disabled: $name"

  write_clients_txt
  build_config
}

enable_client() {
  load_config

  local name="$1"
  [ -z "$name" ] && echo "Client name required" && exit 1
  validate_name "$name"

  local file="$CLIENTS_DIR/${name}.json"
  local disabled_file="$CLIENTS_DIR/${name}.json.disabled"

  [ -f "$file" ] && echo "Client already enabled: $name" && exit 1
  [ ! -f "$disabled_file" ] && echo "Disabled client not found: $name" && exit 1

  mv "$disabled_file" "$file"

  echo "Client enabled: $name"

  write_clients_txt
  build_config
}

rename_client() {
  load_config

  local old="$1"
  local new="$2"

  [ -z "$old" ] && echo "Old name required" && exit 1
  [ -z "$new" ] && echo "New name required" && exit 1

  validate_name "$old"
  validate_name "$new"

  local oldfile="$CLIENTS_DIR/${old}.json"
  local newfile="$CLIENTS_DIR/${new}.json"
  local old_disabled_file="$CLIENTS_DIR/${old}.json.disabled"
  local new_disabled_file="$CLIENTS_DIR/${new}.json.disabled"
  local source_file target_file

  if [ -f "$oldfile" ]; then
    source_file="$oldfile"
    target_file="$newfile"
  elif [ -f "$old_disabled_file" ]; then
    source_file="$old_disabled_file"
    target_file="$new_disabled_file"
  else
    echo "Client not found: $old"
    exit 1
  fi

  if [ -f "$newfile" ] || [ -f "$new_disabled_file" ]; then
    echo "Target client already exists: $new"
    exit 1
  fi

  local tmp_file
  tmp_file="$(mktemp)"

  jq --arg name "$new" '.name = $name' "$source_file" > "$tmp_file"
  mv "$tmp_file" "$target_file"
  rm -f "$source_file"

  echo "Renamed: $old -> $new"

  write_clients_txt
  build_config
}

build_config() {
  load_config

  [ ! -f "$TEMPLATE" ] && echo "Template not found: $TEMPLATE" && exit 1

  local tmp_users
  tmp_users="$(mktemp)"

  if ls "$CLIENTS_DIR"/*.json >/dev/null 2>&1; then
    jq -s 'map({uuid: .uuid, flow: .flow})' "$CLIENTS_DIR"/*.json > "$tmp_users"
  else
    echo "[]" > "$tmp_users"
  fi

  jq --slurpfile users "$tmp_users" \
    '.inbounds[0].users = $users[0]' \
    "$TEMPLATE" > "$BUILD"

  rm -f "$tmp_users"

  jq empty "$BUILD"
  sing-box check -c "$BUILD"

  echo "Config built: $BUILD"
}

verify_config() {
  load_config
  build_config

  echo
  echo "Current config users:"
  jq '.inbounds[0].users | length' "$REAL_CONFIG"

  echo "Built config users:"
  jq '.inbounds[0].users | length' "$BUILD"

  echo
  echo "Duplicate UUID check:"

  local duplicates
  duplicates="$(jq -r '.inbounds[0].users[].uuid' "$BUILD" | sort | uniq -d)"

  if [ -n "$duplicates" ]; then
    echo "Duplicate UUID found:"
    echo "$duplicates"
    exit 1
  fi

  echo "No duplicates."

  echo
  echo "sing-box check:"
  sing-box check -c "$BUILD"

  echo
  echo "Verify complete."
}

import_clients() {
  load_config

  jq -c '.inbounds[0].users[]' "$REAL_CONFIG" | nl -w1 -s' ' | while read -r num user; do
    local uuid flow name file

    uuid="$(echo "$user" | jq -r '.uuid')"
    flow="$(echo "$user" | jq -r '.flow // "xtls-rprx-vision"')"
    name="imported_${num}"
    file="$CLIENTS_DIR/${name}.json"

    if [ -f "$file" ]; then
      echo "Skip existing: $name"
      continue
    fi

    cat > "$file" <<EOF_CLIENT
{
  "name": "$name",
  "uuid": "$uuid",
  "flow": "$flow",
  "created": "$(date +%Y-%m-%d)"
}
EOF_CLIENT
  done

  echo "Import complete."

  write_clients_txt
  build_config
}

ensure_ufw_port() {
  load_config

  if ! command -v ufw >/dev/null 2>&1; then
    return 0
  fi

  if ! ufw status | grep -q "^Status: active"; then
    echo "UFW: inactive."
    return 0
  fi

  if ufw status | grep -qE "(^|[[:space:]])${PORT}/tcp([[:space:]]|$)"; then
    echo "UFW: TCP port ${PORT} already allowed."
    return 0
  fi

  echo "UFW: opening TCP port ${PORT}..."
  ufw allow "${PORT}/tcp"
}

deploy_config() {
  if [ "$EUID" -ne 0 ]; then
    exec sudo VPNCTL_DATA_DIR="$DATA_DIR" "$0" deploy
  fi

  load_config
  verify_config
  ensure_ufw_port

  echo
  echo "About to replace:"
  echo "$REAL_CONFIG"
  echo
  echo "Service to restart:"
  echo "$SERVICE_NAME"
  echo

  read -p "Type yes to continue: " CONFIRM

  [ "$CONFIRM" != "yes" ] && echo "Deploy cancelled." && exit 1

  local backup="$BACKUP_DIR/config-$(date +%Y%m%d-%H%M%S).json"

  cp "$REAL_CONFIG" "$backup"
  cp "$BUILD" "$REAL_CONFIG"

  if ! sing-box check -c "$REAL_CONFIG"; then
    echo "Check failed. Rollback."
    cp "$backup" "$REAL_CONFIG"
    exit 1
  fi

  if ! systemctl restart "$SERVICE_NAME"; then
    echo "Restart failed. Rollback."
    cp "$backup" "$REAL_CONFIG"
    systemctl restart "$SERVICE_NAME"
    exit 1
  fi

  echo "Deploy complete."
  echo "Backup: $backup"
}

setup_server() {
  echo "=== VPNCTL SETUP ==="

  command -v jq >/dev/null 2>&1 || { echo "Install jq first: apt install -y jq"; exit 1; }
  command -v sing-box >/dev/null 2>&1 || { echo "Install sing-box first"; exit 1; }

  read -p "Server IP or domain: " SETUP_SERVER
  read -p "Port [8443]: " SETUP_PORT
  read -p "SNI [www.cloudflare.com]: " SETUP_SNI

  SETUP_PORT="${SETUP_PORT:-8443}"
  SETUP_SNI="${SETUP_SNI:-www.cloudflare.com}"

  if ! echo "$SETUP_PORT" | grep -Eq '^[0-9]+$'; then
    echo "Invalid port: $SETUP_PORT"
    exit 1
  fi

  if [ "$SETUP_PORT" -lt 1 ] || [ "$SETUP_PORT" -gt 65535 ]; then
    echo "Invalid port: $SETUP_PORT"
    echo "Port must be between 1 and 65535"
    exit 1
  fi

  local first_uuid keypair private_key public_key short_id

  first_uuid="$(sing-box generate uuid)"
  keypair="$(sing-box generate reality-keypair)"
  private_key="$(echo "$keypair" | awk '/PrivateKey:/ {print $2}')"
  public_key="$(echo "$keypair" | awk '/PublicKey:/ {print $2}')"
  short_id="$(openssl rand -hex 8)"

  echo
  echo "Generated:"
  echo "UUID: $first_uuid"
  echo "PublicKey: $public_key"
  echo "ShortID: $short_id"

  mkdir -p "$CLIENTS_DIR" "$BUILDS_DIR" "$BACKUP_DIR"

  cat > "$CONFIG_FILE" <<EOF_CONFIG
SERVER=$SETUP_SERVER
PORT=$SETUP_PORT
SNI=$SETUP_SNI
PUBLIC_KEY=$public_key
SHORT_ID=$short_id
FLOW=xtls-rprx-vision
EOF_CONFIG

  cat > "$TEMPLATE" <<EOF_TEMPLATE
{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-reality-in",
      "listen": "::",
      "listen_port": $SETUP_PORT,
      "users": [],
      "tls": {
        "enabled": true,
        "server_name": "$SETUP_SNI",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "$SETUP_SNI",
            "server_port": 443
          },
          "private_key": "$private_key",
          "short_id": [
            "$short_id"
          ]
        }
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ]
}
EOF_TEMPLATE

  rm -f "$CLIENTS_DIR"/*.json "$CLIENTS_DIR"/*.json.disabled

  cat > "$CLIENTS_DIR/main.json" <<EOF_CLIENT
{
  "name": "main",
  "uuid": "$first_uuid",
  "flow": "xtls-rprx-vision",
  "created": "$(date +%Y-%m-%d)"
}
EOF_CLIENT

  source "$CONFIG_FILE"

  write_clients_txt
  build_config

  echo
  echo "Setup complete."
  echo
  echo "First client link:"
  make_link "$first_uuid" "main"
  echo
  echo "All client links:"
  echo "$CLIENTS_TXT"
  echo
  echo "Run deploy when ready:"
  echo "vpnctl deploy"
}

print_usage() {
  echo "Usage:"
  echo "  vpnctl add <name>"
  echo "  vpnctl list"
  echo "  vpnctl show <name>"
  echo "  vpnctl remove <name>"
  echo "  vpnctl rename <old> <new>"
  echo "  vpnctl verify"
  echo "  vpnctl import"
  echo "  vpnctl deploy"
  echo "  vpnctl disable <name>"
  echo "  vpnctl enable <name>"
  echo "  vpnctl setup"
}

case "$1" in
  add) add_client "$2" ;;
  list) list_clients ;;
  show) show_client "$2" ;;
  remove) remove_client "$2" ;;
  disable) disable_client "$2" ;;
  enable) enable_client "$2" ;;
  rename) rename_client "$2" "$3" ;;
  build) build_config ;;
  verify) verify_config ;;
  import) import_clients ;;
  deploy) deploy_config ;;
  setup) setup_server ;;
  *) print_usage ;;
esac
